{
  "name": "datalox-pack",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Portable Datalox pack with loop-time skill detection and pattern docs.",
  "scripts": {
    "agent:bootstrap": "node scripts/agent-bootstrap.mjs",
    "agent:resolve": "node scripts/agent-resolve.mjs",
    "agent:lint": "node scripts/agent-lint.mjs",
    "agent:learn-pattern": "node scripts/agent-learn-pattern.mjs",
    "agent:learn-skill": "node scripts/agent-learn-skill.mjs",
    "agent:learn-from-interaction": "node scripts/agent-learn-from-interaction.mjs",
    "build": "tsc",
    "prepare": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
