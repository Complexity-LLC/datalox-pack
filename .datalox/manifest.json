{
  "version": 1,
  "kind": "portable_knowledge_pack",
  "name": "Datalox Pack",
  "mode": "repo_only",
  "runtimeRequired": false,
  "configPath": ".datalox/config.json",
  "instructionPaths": [
    "DATALOX.md",
    "AGENTS.md",
    "CLAUDE.md",
    "WIKI.md",
    "GEMINI.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/datalox-pack.mdc",
    ".windsurf/rules/datalox-pack.md"
  ],
  "entrypoints": {
    "seedSkillsDir": "skills",
    "seedPatternsDir": ".datalox/patterns",
    "hostSkillsDir": null,
    "hostPatternsDir": null
  },
  "controlArtifacts": {
    "indexPath": ".datalox/index.md",
    "logPath": ".datalox/log.md",
    "lintPath": ".datalox/lint.md"
  },
  "startup": {
    "readOnEveryLoop": true,
    "readOrder": [
      ".datalox/config.local.json",
      ".datalox/config.json",
      "DATALOX.md",
      "AGENTS.md",
      "CLAUDE.md",
      "WIKI.md",
      "GEMINI.md"
    ],
    "skillSelectionSignals": [
      "current task text",
      "current workflow if known",
      "git changed paths when available",
      "repo root files",
      "package metadata"
    ]
  },
  "agentRules": {
    "preserveNativeSkills": true,
    "generatedSkillsDir": "skills",
    "patternDocsDir": ".datalox/patterns",
    "hostRepoOwnsWrites": true
  },
  "distribution": {
    "oneClickBootstrap": "bash bin/adopt-from-github.sh <host-repo>",
    "multiAgentSetup": "bash bin/setup-multi-agent.sh",
    "friendlyEntryPoint": "START_HERE.md"
  }
}
