{
  "version": 1,
  "kind": "portable_knowledge_pack",
  "name": "Datalox Pack",
  "mode": "repo_only",
  "runtimeRequired": false,
  "configPath": ".datalox/config.json",
  "instructionPaths": [
    "DATALOX.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "entrypoints": {
    "skillsDir": "skills",
    "patternsDir": ".datalox/patterns"
  },
  "startup": {
    "readOnEveryLoop": true,
    "readOrder": [
      ".datalox/config.local.json",
      ".datalox/config.json",
      "DATALOX.md",
      "AGENTS.md",
      "CLAUDE.md"
    ],
    "skillSelectionSignals": [
      "current task text",
      "current workflow if known",
      "git changed paths when available",
      "repo root files",
      "package metadata"
    ]
  },
  "agentRules": {
    "preserveNativeSkills": true,
    "generatedSkillsDir": "skills",
    "patternDocsDir": ".datalox/patterns"
  }
}
