{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datalox.dev/schemas/config.schema.json",
  "title": "Datalox Agent Config",
  "type": "object",
  "required": [
    "version",
    "mode",
    "project",
    "sources",
    "agent",
    "paths",
    "runtime",
    "auth"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "repo_only",
        "service_backed"
      ]
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "name",
          "enabled",
          "root"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "local_repo"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "root": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "agent": {
      "type": "object",
      "required": [
        "profile",
        "nativeSkillPolicy",
        "detectOnEveryLoop",
        "configReadOrder",
        "interfaceOrder"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "enum": [
            "local_first",
            "runtime_first"
          ]
        },
        "nativeSkillPolicy": {
          "type": "string",
          "enum": [
            "preserve"
          ]
        },
        "detectOnEveryLoop": {
          "type": "boolean"
        },
        "configReadOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "interfaceOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "skill_loop",
              "runtime_compile"
            ]
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": [
        "seedSkillsDir",
        "seedPatternsDir",
        "hostSkillsDir",
        "hostPatternsDir"
      ],
      "properties": {
        "seedSkillsDir": {
          "type": "string",
          "minLength": 1
        },
        "seedPatternsDir": {
          "type": "string",
          "minLength": 1
        },
        "hostSkillsDir": {
          "type": "string",
          "minLength": 1
        },
        "hostPatternsDir": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": [
        "enabled",
        "baseUrl",
        "defaultWorkflow",
        "requestTimeoutMs",
        "endpoints"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "defaultWorkflow": {
          "type": "string",
          "minLength": 1
        },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "endpoints": {
          "type": "object",
          "required": [
            "compile"
          ],
          "properties": {
            "compile": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "required": [
        "apiKeyEnv",
        "contributorKeyEnv"
      ],
      "properties": {
        "apiKeyEnv": {
          "type": "string",
          "minLength": 1
        },
        "contributorKeyEnv": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
